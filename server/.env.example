PORT=5009
NODE_ENV=development

# CORS (optional)
CLIENT_URL=http://localhost:5009

# LLM provider (optional). If not set, the server will use deterministic generation.
# NOTE: keep example values as placeholders; do NOT paste real keys here.
# GROQ_API_KEY=your_groq_api_key
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENAI_API_KEY=your_openai_api_key
# LLM_MODEL=
# LLM_TIMEOUT_MS=90000

# Text → plan 2D tuning (optional)
# TEXT2D_PLAN_MAX_INPUT_LENGTH=6000
# TEXT2D_PLAN_CACHE_TTL_MS=300000
# TEXT2D_PLAN_CACHE_MAX=200
# TEXT2D_ARCH_GUIDE_MAX_CHARS=

# Optional external geometry solver (Python) to produce better layouts
# GEOMETRY_SERVICE_URL=http://127.0.0.1:8008
# PLAN2D_PREFER_LOCAL_SOLVER=true
